generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Player account ────────────────────────────────────────────────
model Player {
  id             String          @id @default(cuid())
  email          String          @unique
  coins          Int             @default(0)
  heroInstances  HeroInstance[]
  inventory      InventoryItem[]
  levelProgress  PlayerLevelProgress[]
  skillUnlocks   PlayerSkillUnlock[]
  pets           PlayerPet[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// Legacy: kept during migration, will be removed after Player is fully rolled out
model PlayerProgress {
  id        String   @id @default(cuid())
  sessionId String   @unique
  coins     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ── Game config: heroes ───────────────────────────────────────────
model Hero {
  id             String         @id @default(cuid())
  name           String
  spriteSet      String         @default("hero")
  heroClass      String         @default("warrior")
  cost           Int            @default(0)
  level          Int            @default(1)
  hp             Int            @default(26)
  attack         Int            @default(4)
  defense        Int            @default(0)
  attackCooldown Float          @default(1.5)
  walkSpeed      Int            @default(220)
  attackRange    Int            @default(1)
  groupPosition  Int            @default(0)
  isActive       Boolean        @default(false)
  instances      HeroInstance[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model HeroInstance {
  id            String      @id @default(cuid())
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  heroId        String
  hero          Hero        @relation(fields: [heroId], references: [id])
  level         Int         @default(1)
  xp            Int         @default(0)
  groupPosition Int?
  equipment     Equipment[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([playerId, heroId])
}

model Equipment {
  id              String        @id @default(cuid())
  heroInstanceId  String
  heroInstance    HeroInstance  @relation(fields: [heroInstanceId], references: [id], onDelete: Cascade)
  slot            String
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([heroInstanceId, slot])
}

// ── Game config: monsters ─────────────────────────────────────────
model Monster {
  id                  String        @id @default(cuid())
  name                String
  spriteSet           String        @default("zombie")
  monsterType         String        @default("UNDEAD")
  isBoss              Boolean       @default(false)
  sizeMultiplier      Float         @default(1.0)
  attackBehavior      String        @default("MELEE")
  secondaryBehavior   String?
  behaviorSwitchHpPct Float?
  hp                  Int           @default(12)
  attack              Int           @default(1)
  defense             Int           @default(0)
  attackCooldown      Float         @default(2.2)
  walkSpeed           Int           @default(42)
  attackRange         Int           @default(1)
  coinDropMin         Int           @default(1)
  coinDropMax         Int           @default(2)
  baseXp              Int           @default(8)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  waveEntries         WaveMonster[]
  lootEntries         LootEntry[]
}

// ── Game config: rounds ───────────────────────────────────────────
model Round {
  id                   String   @id @default(cuid())
  number               Int      @unique
  name                 String
  chestCommonChance    Float    @default(0.5)
  chestUncommonChance  Float    @default(0.25)
  chestRareChance      Float    @default(0.1)
  chestLegendaryChance Float    @default(0.02)
  waves                Wave[]
  levels               Level[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Wave {
  id        String        @id @default(cuid())
  roundId   String
  round     Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  order     Int
  triggerX  Int           @default(640)
  monsters  WaveMonster[]
  createdAt DateTime      @default(now())
}

model WaveMonster {
  id        String  @id @default(cuid())
  waveId    String
  wave      Wave    @relation(fields: [waveId], references: [id], onDelete: Cascade)
  monsterId String
  monster   Monster @relation(fields: [monsterId], references: [id])
  offsetX   Int     @default(0)
  levelMult Float   @default(1.0)
}

// ── Items ─────────────────────────────────────────────────────────
model Item {
  id             String          @id @default(cuid())
  name           String
  description    String?
  type           ItemType
  rarity         Rarity          @default(COMMON)
  statBonus      Json            @default("{}")
  iconUrl        String?
  equipSlot      String?
  requiredLevel  Int             @default(1)
  requiredClass  String?
  socketCount    Int             @default(0)
  lootEntries    LootEntry[]
  inventoryItems InventoryItem[]
}

model LootEntry {
  id         String  @id @default(cuid())
  monsterId  String
  monster    Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item    @relation(fields: [itemId], references: [id])
  dropChance Float   @default(0.1)
  minQty     Int     @default(1)
  maxQty     Int     @default(1)
}

model InventoryItem {
  id         String      @id @default(cuid())
  playerId   String
  player     Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item        @relation(fields: [itemId], references: [id])
  quantity   Int         @default(1)
  obtainedAt DateTime    @default(now())
  equipment  Equipment[]

  @@index([playerId])
}

// ── Map hierarchy ─────────────────────────────────────────────────
model World {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  zones       Zone[]
}

model Zone {
  id          String   @id @default(cuid())
  worldId     String
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  name        String
  description String?
  order       Int      @default(0)
  levels      Level[]
}

model Level {
  id               String                @id @default(cuid())
  zoneId           String
  zone             Zone                  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name             String
  number           Int
  roundId          String
  round            Round                 @relation(fields: [roundId], references: [id])
  recommendedLevel Int                   @default(1)
  progress         PlayerLevelProgress[]
}

model PlayerLevelProgress {
  id          String    @id @default(cuid())
  playerId    String
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  levelId     String
  level       Level     @relation(fields: [levelId], references: [id], onDelete: Cascade)
  stars       Int       @default(0)
  completedAt DateTime?

  @@unique([playerId, levelId])
}

// ── Global skill tree ─────────────────────────────────────────────
model SkillNode {
  id          String               @id @default(cuid())
  name        String
  description String
  costCoins   Int
  statBonus   Json
  order       Int                  @default(0)
  unlocks     PlayerSkillUnlock[]
}

model PlayerSkillUnlock {
  id          String    @id @default(cuid())
  playerId    String
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  nodeId      String
  node        SkillNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  unlockedAt  DateTime  @default(now())

  @@unique([playerId, nodeId])
}

// ── Pets ─────────────────────────────────────────────────────────
model Pet {
  id          String      @id
  name        String
  description String
  rarity      String      @default("COMMON")
  buffStats   Json
  cost        Int         @default(0)
  isActive    Boolean     @default(true)
  playerPets  PlayerPet[]
}

model PlayerPet {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  petId    String
  pet      Pet     @relation(fields: [petId], references: [id])
  isActive Boolean @default(false)

  @@unique([playerId, petId])
}

enum ItemType {
  WEAPON
  ARMOR
  HELMET
  BOOTS
  ACCESSORY
  CONSUMABLE
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  LEGENDARY
}
